# =============================================================================
# Nexus environment template — copy to .env (never commit .env).
# Also set the same categories in Lovable / Cloudflare / Codemagic as noted.
# =============================================================================

# -----------------------------------------------------------------------------
# A. Public browser (Vite) — safe to expose; baked into client bundles
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Dev/preview only. FORBIDDEN in production builds (runtime throws).
# Omit unset for live data when keys above are set.
# VITE_USE_MOCK=1

# -----------------------------------------------------------------------------
# B. Server-only secrets — createServerFn / Nitro. NEVER prefix with VITE_
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin / platform roles — comma-separated profile/auth user UUIDs (server-only).
# Bootstrap + break-glass into public.platform_roles (see docs/ADMIN-SECURITY.md).
# After first successful admin login, durable access lives in the DB.
# ADMIN_USER_IDS=11111111-1111-1111-1111-111111111111

# LiveKit (hub + DM voice). Without these, VoiceDock uses stub join.
# From https://cloud.livekit.io → Project → Settings → Keys
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# Web Push (Phase 11). Generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:safety@nexus.app
# Optional client mirror of the public key:
# VITE_VAPID_PUBLIC_KEY=
# Database Webhook auth for POST /api/push-dispatch
# PUSH_DISPATCH_SECRET=
# -----------------------------------------------------------------------------
# C. Deployment / origins
# -----------------------------------------------------------------------------
# Production site origin (sitemap absolute URLs + OAuth redirect base)
# SITE_URL=https://your-domain.com

# Capacitor iOS shell — HTTPS origin loaded inside the native WebView
# (Codemagic env group for IPA builds; must be HTTPS; no trailing slash)
# CAPACITOR_SERVER_URL=https://your-domain.com
# CAPACITOR_REQUIRE_SERVER=1   # optional local fail-closed for prepare (CI sets this)
#
# Dual-mode notes: docs/CAPACITOR.md — remote = TestFlight; local www ≠ createServerFn
#
# Supabase → Authentication → URL Configuration — add:
#   com.lilnetro0.nexus://auth/callback

# Native push send (Phase 18 follow-up). Tokens already register via Cap plugin.
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=com.lilnetro0.nexus
# APNS_P8=-----BEGIN PRIVATE KEY-----...   # or APNS_P8_BASE64=
# APNS_PRODUCTION=1                        # unset → sandbox host in non-production
# FCM_SERVER_KEY=                          # Android Cap tokens (legacy HTTP; prefer HTTP v1 later)

# Ops (Phase 16) — see docs/OPS.md
# HEALTH_CHECK_URL=https://your-domain.com          # or full …/api/health; used by npm run ops:health
# OPS_HEALTH_REQUIRE=1                              # CI: fail if no health URL env
# OPS_ALERT_WEBHOOK_URL=https://hooks.slack.com/…   # Slack Incoming Webhook (error logs)
# OPS_PAGERDUTY_ROUTING_KEY=                        # Events API v2 routing key (optional)

# -----------------------------------------------------------------------------
# D. Production checklist (fail-closed client)
# -----------------------------------------------------------------------------
# - VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY MUST be set
# - VITE_USE_MOCK MUST be unset / not 1|true
# - SUPABASE_SERVICE_ROLE_KEY MUST be set on the server (admin client fails closed)
# - VITE_USE_MOCK MUST be unset / not 1|true
# See docs/DATABASE-OPERATIONS.md and docs/PRODUCTION-HARDENING-PLAN.md

# After each DB apply: run supabase/verify_schema.sql on that project (no MISSING rows).
