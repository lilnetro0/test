# Copy to .env (never commit .env). Also set these in Lovable project settings.

# Public (safe for the browser)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Server-only — used inside createServerFn. NEVER prefix with VITE_
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Mock: omit or leave unset to use LIVE data when Supabase keys are set.
# Set to 1 / true to force mock chat/friends even with keys.
# VITE_USE_MOCK=1

# Admin ban UI — comma-separated profile/auth user UUIDs (server-only, never VITE_)
# ADMIN_USER_IDS=11111111-1111-1111-1111-111111111111

# Phase 5 — LiveKit (server-only secrets; never VITE_)
# From https://cloud.livekit.io → Project → Settings → Keys
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
#
# With LiveKit set: real WebRTC for hub voice + DM voice.
# Without them: VoiceDock falls back to stub join.

# Production site origin (sitemap absolute URLs + OAuth redirect base)
# SITE_URL=https://your-domain.com

# Capacitor iOS shell — HTTPS origin loaded inside the native WebView
# (set the same value as a Codemagic env var for IPA builds)
# CAPACITOR_SERVER_URL=https://your-domain.com
