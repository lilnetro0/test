{
  "name": "tanstack_start_ts",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:ci": "eslint -c eslint.ci.config.js src",
    "format": "prettier --write .",
    "format:check": "prettier --check \"src/lib/rate-limit.ts\" \"src/lib/trust-safety.ts\" \"src/lib/hub/permissions.ts\" \"src/lib/supabase/env.ts\" \"src/lib/supabase/storage-policy.ts\" \"src/lib/ops/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.ci.json",
    "typecheck:full": "tsc --noEmit",
    "smoke:security": "node scripts/smoke-security.cjs",
    "smoke:launch": "node scripts/smoke-launch.cjs",
    "ci:verify": "npm test && npm run typecheck && npm run typecheck:full && npm run smoke:security && npm run lint:ci && npm run smoke:launch",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "cap:prepare": "node scripts/prepare-capacitor-www.cjs",
    "cap:inject-server": "node scripts/inject-capacitor-server-url.cjs",
    "cap:sync": "npm run cap:prepare && npx cap sync && npm run cap:inject-server",
    "cap:sync:local": "node scripts/prepare-capacitor-www.cjs && npx cap sync ios",
    "cap:smoke": "node scripts/smoke-capacitor.cjs",
    "cap:android:init": "npx cap add android",
    "ops:health": "node scripts/smoke-health.cjs",
    "mobile:ios": "npm run build && npm run cap:sync"
  },
